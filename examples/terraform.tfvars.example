# Copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored and must never be committed.

fb_url    = "10.10.10.2"
api_token = "T-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

s3_accounts = {
  "myteam" = {
    # quota      = "1T"
    # hard_limit = true
  }
}

buckets = {
  "my-bucket-1" = {
    account_name = "myteam"
    versioning   = "enabled"
    quota        = "100G"
  }
  "my-bucket-2" = {
    account_name = "myteam"
  }
}
